    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
